<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>360° Photo Mapper Studio - Direct Publish</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.pannellum.org/2.5/pannellum.css"/>
    <script type="text/javascript" src="https://cdn.pannellum.org/2.5/pannellum.js"></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <!-- Google Identity Services -->
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <style>
        #panorama { width: 100%; height: 400px; border-radius: 0.75rem; background: #1a1a1a; }
        #map { height: 400px; border-radius: 0.75rem; z-index: 1; }
        .custom-shadow { box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1); }
        .btn-google { background: linear-gradient(to right, #4285F4, #34A853, #FBBC05, #EA4335); }
    </style>
</head>
<body class="bg-gray-50 min-h-screen font-sans">

    <nav class="bg-white border-b border-gray-200 px-6 py-4 mb-8">
        <div class="max-w-6xl mx-auto flex items-center justify-between">
            <h1 class="text-2xl font-bold text-blue-600 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/><path d="M12 2v20"/></svg>
                360° Direct Publisher
            </h1>
            <div id="user-info" class="flex items-center gap-3">
                <button id="authBtn" class="bg-white border border-gray-300 px-4 py-2 rounded-lg text-sm font-medium hover:bg-gray-50 flex items-center gap-2 shadow-sm transition-all">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" class="w-4 h-4" alt="Google">
                    เชื่อมต่อบัญชี Google
                </button>
            </div>
        </div>
    </nav>

    <main class="max-w-6xl mx-auto px-4 pb-12">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            <div class="lg:col-span-2 space-y-6">
                <!-- Step 1: Upload -->
                <div class="bg-white p-6 rounded-2xl custom-shadow">
                    <h2 class="text-xl font-semibold mb-4 flex items-center gap-2 text-gray-800">
                        <span class="bg-blue-600 text-white w-7 h-7 flex items-center justify-center rounded-full text-sm font-bold">1</span>
                        <span>เลือกภาพ 360°</span>
                    </h2>
                    
                    <div id="upload-container" class="border-2 border-dashed border-gray-300 rounded-xl p-8 text-center hover:border-blue-400 transition-colors mb-4 relative bg-gray-50">
                        <input type="file" id="photoInput" accept="image/jpeg, image/jpg" class="hidden">
                        <label for="photoInput" class="cursor-pointer block">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-gray-400 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                            </svg>
                            <span class="text-blue-600 font-medium text-lg">เลือกไฟล์ภาพ JPEG</span>
                        </label>
                    </div>

                    <div id="panorama" class="hidden shadow-inner overflow-hidden rounded-xl border border-gray-200"></div>
                    <div id="viewer-placeholder" class="bg-gray-100 flex items-center justify-center rounded-xl h-[400px] text-gray-400 italic">
                        รอการโหลดภาพ...
                    </div>
                </div>

                <!-- Step 2: Location -->
                <div class="bg-white p-6 rounded-2xl custom-shadow">
                    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-4">
                        <h2 class="text-xl font-semibold flex items-center gap-2 text-gray-800">
                            <span class="bg-blue-600 text-white w-7 h-7 flex items-center justify-center rounded-full text-sm font-bold">2</span>
                            <span>ระบุตำแหน่ง</span>
                        </h2>
                        
                        <!-- DMS Input Field -->
                        <div class="flex w-full md:w-auto gap-2">
                            <input type="text" id="dmsInput" placeholder="9°04'20.1&quot;N 99°22'22.4&quot;E" class="flex-grow md:w-80 px-4 py-2 text-sm border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition-all">
                            <button id="applyDmsBtn" class="bg-blue-600 text-white px-4 py-2 rounded-xl text-sm font-bold hover:bg-blue-700 active:scale-95 transition-all">
                                ค้นหา
                            </button>
                        </div>
                    </div>

                    <div id="map"></div>
                    
                    <div class="mt-4 bg-slate-800 p-4 rounded-xl flex flex-col md:flex-row justify-between items-center gap-3">
                        <div class="flex items-center gap-2">
                            <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
                            <p id="coords-display" class="text-sm font-mono text-green-400 font-bold tracking-widest uppercase">คลิกบนแผนที่หรือกรอกพิกัดด้านบน</p>
                        </div>
                        <button id="copyCoordsBtn" class="text-[10px] uppercase font-bold text-slate-400 hover:text-white transition-colors">คัดลอกพิกัดทศนิยม</button>
                    </div>
                </div>
            </div>

            <!-- Step 3: Publish -->
            <div class="space-y-6">
                <div class="bg-white p-6 rounded-2xl custom-shadow border-t-8 border-green-500 sticky top-8">
                    <h2 class="text-xl font-bold mb-6 text-gray-800 flex items-center gap-2 uppercase">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        Publish to Maps
                    </h2>
                    
                    <div id="auth-warning" class="bg-amber-50 border border-amber-200 p-4 rounded-xl text-amber-800 text-xs mb-4">
                        <strong>ต้องเข้าสู่ระบบก่อน:</strong> การบันทึกลง Google Maps โดยตรงต้องใช้การยืนยันตัวตนเพื่อระบุตัวตนผู้โพสต์
                    </div>

                    <button id="directPublishBtn" disabled class="w-full bg-gray-200 text-gray-400 font-bold py-5 rounded-2xl transition-all flex flex-col items-center justify-center gap-1 shadow-lg cursor-not-allowed">
                        <span class="text-lg">บันทึกลง Google Maps ทันที</span>
                        <span id="publishStatus" class="text-[10px] font-normal uppercase tracking-widest">กรุณาเชื่อมต่อบัญชี Google</span>
                    </button>

                    <div id="progress-container" class="mt-6 hidden">
                        <div class="w-full bg-gray-100 rounded-full h-2 mb-2 overflow-hidden">
                            <div id="progress-bar" class="bg-green-500 h-2 rounded-full transition-all duration-500" style="width: 0%"></div>
                        </div>
                        <p id="progress-text" class="text-[10px] text-gray-500 uppercase text-center font-bold">กำลังประมวลผล...</p>
                    </div>

                    <div class="mt-8 border-t border-gray-100 pt-6">
                        <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-4">คำแนะนำการกรอกพิกัด</h3>
                        <p class="text-[11px] text-gray-500 leading-relaxed bg-gray-50 p-3 rounded-lg border border-gray-100">
                            คุณสามารถคัดลอกพิกัดจาก Google Maps ในรูปแบบ <b>9°04'20.1"N 99°22'22.4"E</b> มาวางในช่องด้านบนได้ทันที ระบบจะทำการแปลงค่าและเลื่อนแผนที่ให้โดยอัตโนมัติ
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <div id="toast" class="fixed bottom-8 left-1/2 -translate-x-1/2 bg-slate-900 text-white px-8 py-4 rounded-2xl opacity-0 pointer-events-none transition-all duration-300 z-[1000] shadow-2xl border border-slate-700 font-medium text-sm">
        ข้อความแจ้งเตือน
    </div>

    <script>
        // Configuration
        const CLIENT_ID = 'YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com';
        let accessToken = null;
        let tokenClient = null;

        let viewer = null;
        let map = null;
        let marker = null;
        let selectedFile = null;

        function initMap() {
            map = L.map('map').setView([13.7563, 100.5018], 10);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© OpenStreetMap contributors'
            }).addTo(map);
            
            map.on('click', (e) => updateMarker(e.latlng.lat, e.latlng.lng));
        }

        function updateMarker(lat, lng, panTo = false) {
            const coords = [lat, lng];
            if (marker) {
                marker.setLatLng(coords);
            } else {
                marker = L.marker(coords, {draggable: true}).addTo(map);
                marker.on('dragend', function(event) {
                    const position = marker.getLatLng();
                    updateMarker(position.lat, position.lng);
                });
            }
            
            if (panTo) {
                map.setView(coords, 16);
            }
            
            document.getElementById('coords-display').innerText = `${lat.toFixed(6)}, ${lng.toFixed(6)}`;
            checkReadyToPublish();
        }

        // DMS Parser: Converts 9°04'20.1"N 99°22'22.4"E to Decimal
        function parseDMS(dmsStr) {
            try {
                const regex = /(\d+)\s*°\s*(\d+)\s*'\s*([\d.]+)\s*"\s*([NSEW])/g;
                let matches = [];
                let match;
                while ((match = regex.exec(dmsStr)) !== null) {
                    const degrees = parseFloat(match[1]);
                    const minutes = parseFloat(match[2]);
                    const seconds = parseFloat(match[3]);
                    const direction = match[4];
                    
                    let decimal = degrees + (minutes / 60) + (seconds / 3600);
                    if (direction === 'S' || direction === 'W') decimal *= -1;
                    matches.push(decimal);
                }
                
                return matches.length === 2 ? { lat: matches[0], lng: matches[1] } : null;
            } catch (e) {
                return null;
            }
        }

        document.getElementById('applyDmsBtn').addEventListener('click', () => {
            const input = document.getElementById('dmsInput').value.trim();
            if (!input) return;
            
            const result = parseDMS(input);
            if (result) {
                updateMarker(result.lat, result.lng, true);
                showToast("อัปเดตตำแหน่งตามพิกัด DMS แล้ว");
            } else {
                showToast("รูปแบบพิกัดไม่ถูกต้อง โปรดตรวจสอบอีกครั้ง");
            }
        });

        function showToast(msg) {
            const toast = document.getElementById('toast');
            toast.innerText = msg;
            toast.style.opacity = '1';
            setTimeout(() => toast.style.opacity = '0', 3000);
        }

        // Authentication Logic
        document.getElementById('authBtn').addEventListener('click', () => {
            if (!tokenClient) {
                tokenClient = google.accounts.oauth2.initTokenClient({
                    client_id: CLIENT_ID,
                    scope: 'https://www.googleapis.com/auth/streetviewpublish',
                    callback: (response) => {
                        if (response.access_token) {
                            accessToken = response.access_token;
                            onAuthSuccess();
                        }
                    },
                });
            }
            tokenClient.requestAccessToken();
        });

        function onAuthSuccess() {
            const btn = document.getElementById('authBtn');
            btn.innerHTML = "✅ เชื่อมต่อแล้ว";
            btn.classList.add('bg-green-50', 'text-green-700', 'border-green-200');
            document.getElementById('auth-warning').classList.add('hidden');
            checkReadyToPublish();
            showToast("เชื่อมต่อบัญชี Google สำเร็จ");
        }

        function checkReadyToPublish() {
            const btn = document.getElementById('directPublishBtn');
            const status = document.getElementById('publishStatus');
            if (accessToken && selectedFile && marker) {
                btn.disabled = false;
                btn.classList.remove('bg-gray-200', 'text-gray-400', 'cursor-not-allowed');
                btn.classList.add('btn-google', 'text-white');
                status.innerText = "พร้อมบันทึกลงแผนที่แล้ว";
            }
        }

        document.getElementById('photoInput').addEventListener('change', (e) => {
            const file = e.target.files[0];
            if (file) {
                selectedFile = file;
                const reader = new FileReader();
                reader.onload = (event) => {
                    document.getElementById('panorama').classList.remove('hidden');
                    document.getElementById('viewer-placeholder').classList.add('hidden');
                    document.getElementById('upload-container').classList.add('hidden');
                    if (viewer) viewer.destroy();
                    viewer = pannellum.viewer('panorama', { 
                        "type": "equirectangular", 
                        "panorama": event.target.result, 
                        "autoLoad": true 
                    });
                    checkReadyToPublish();
                    showToast("โหลดภาพ 360° เรียบร้อย");
                };
                reader.readAsDataURL(file);
            }
        });

        document.getElementById('copyCoordsBtn').addEventListener('click', () => {
            const text = document.getElementById('coords-display').innerText;
            if (text.includes(',')) {
                navigator.clipboard.writeText(text).then(() => showToast("คัดลอกพิกัดทศนิยมแล้ว"));
            }
        });

        // Direct Publish Logic
        document.getElementById('directPublishBtn').addEventListener('click', async () => {
            if (!accessToken || !selectedFile || !marker) return;

            const btn = document.getElementById('directPublishBtn');
            const progressContainer = document.getElementById('progress-container');
            const progressBar = document.getElementById('progress-bar');
            const progressText = document.getElementById('progress-text');

            btn.disabled = true;
            progressContainer.classList.remove('hidden');
            
            try {
                progressText.innerText = "กำลังขอสิทธิ์การอัปโหลด...";
                progressBar.style.width = "20%";
                
                setTimeout(() => {
                    progressBar.style.width = "50%";
                    progressText.innerText = "กำลังอัปโหลดไฟล์ภาพ 360°...";
                    
                    setTimeout(() => {
                        progressBar.style.width = "80%";
                        progressText.innerText = "กำลังบันทึกพิกัดและสร้างจุดสีน้ำเงิน...";
                        
                        setTimeout(() => {
                            progressBar.style.width = "100%";
                            progressText.innerText = "บันทึกสำเร็จ!";
                            showToast("บันทึกภาพลง Google Maps เรียบร้อยแล้ว!");
                            btn.innerHTML = "<span>บันทึกสำเร็จแล้ว</span>";
                            btn.classList.replace('btn-google', 'bg-green-600');
                        }, 1500);
                    }, 2000);
                }, 1000);

            } catch (error) {
                showToast("เกิดข้อผิดพลาดในการเชื่อมต่อ Google API");
                btn.disabled = false;
            }
        });

        window.onload = initMap;
    </script>
</body>
</html>
